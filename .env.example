# ───────────────────────────────────────────────────────────────
# AI Analytics Assistant — Environment template
# Copy to .env and fill real values. NEVER commit .env.
# ───────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ───
DB_HOST=localhost
DB_PORT=5433
DB_NAME=aiassistant_db
DB_USER=postgres
DB_PASSWORD=your-db-password
# Read-only role the LLM-generated SQL runs as (safety layer)
DB_READONLY_USER=readonly
DB_READONLY_PASSWORD=your-readonly-password

# ───────────────────────────────────────────────────────────────
# LLM PROVIDERS — multi-provider, switchable from the UI.
# You only need a key for the provider(s) you actually use.
# The UI lets you pick provider + model + paste a key at runtime;
# these env vars are the DEFAULT fallback when no key is typed.
# ───────────────────────────────────────────────────────────────

# Default provider on app startup (claude | groq | gemini | openai | deepseek | ollama)
DEFAULT_LLM_PROVIDER=groq

# ─── Claude (Anthropic — best SQL quality) ───
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Gemini (Google AI Studio — free tier) ───
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── OpenAI ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── DeepSeek (OpenAI-compatible, very cheap) ───
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ─── Groq (OpenAI-compatible, free + fast) ───
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama (local, offline, no key) ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ───────────────────────────────────────────────────────────────
# STREAMING + DATA LAKE
# Ingest path: CoinGecko → Kafka producer → consumer → MinIO (raw) + Postgres.
# Defaults match docker/docker-compose.yml; override only if you change ports.
# ───────────────────────────────────────────────────────────────

# ─── Kafka ───
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=crypto.ticks
KAFKA_CONSUMER_GROUP=crypto-sink

# ─── MinIO (S3-compatible raw data lake) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=your-minio-password
MINIO_BUCKET=crypto-raw
MINIO_SECURE=false
